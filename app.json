{
  "expo": {
    "name": "Coinzy",
    "slug": "coinzy",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0E14"
    },
    "android": {
      "package": "com.coinzy.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#060814"
      },
      "permissions": ["RECEIVE_SMS", "READ_SMS"]
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6C6FE0",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "7217b0e1-ff82-4b6a-a14e-679a59153f20"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/7217b0e1-ff82-4b6a-a14e-679a59153f20"
    }
  }
}